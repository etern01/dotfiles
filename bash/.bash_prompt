# ~/.bash_prompt - Custom prompt configuration
# Defines PS1 with git branch, environment indicator, and exit code

# ============================================
# Colors (without \[\] - added in PS1)
# ============================================
RESET='\033[0m'
BOLD='\033[1m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
GRAY='\033[0;90m'

# Escape sequences for PS1
function _p() { echo -n "\[$1\]"; }

# ============================================
# Environment detection
# ============================================
detect_env() {
    if [ -n "$ENV_TYPE" ]; then
        echo "$ENV_TYPE"
    elif [[ "$HOSTNAME" == *"prod"* ]] || [[ "$HOSTNAME" == *"production"* ]]; then
        echo "PROD"
    elif [[ "$HOSTNAME" == *"staging"* ]] || [[ "$HOSTNAME" == *"stage"* ]]; then
        echo "STAGE"
    elif [[ "$HOSTNAME" == *"dev"* ]] || [[ "$HOSTNAME" == *"development"* ]]; then
        echo "DEV"
    fi
}

# ============================================
# Git branch
# ============================================
parse_git_branch() {
    local branch
    branch=$(git symbolic-ref --short HEAD 2>/dev/null || git describe --tags --exact-match 2>/dev/null)
    if [ -n "$branch" ]; then
        echo " ($branch)"
    fi
}

# ============================================
# Build prompt
# ============================================
build_prompt() {
    # Save exit code FIRST before any other command
    local last_exit=$?

    local git_branch=$(parse_git_branch)
    local env=$(detect_env)

    # Color user based on root or not
    local user_color=$GREEN
    if [ "$EUID" -eq 0 ]; then
        user_color=$RED
    fi

    # Color environment indicator
    local env_color=$GRAY
    local env_display=""
    case "$env" in
        PROD)
            env_color=$RED
            env_display=" [PROD]"
            ;;
        STAGE)
            env_color=$YELLOW
            env_display=" [STAGE]"
            ;;
        DEV)
            env_color=$CYAN
            env_display=" [DEV]"
            ;;
    esac

    # Exit code indicator
    local exit_code=""
    if [ $last_exit -ne 0 ]; then
        exit_code=" [$last_exit]"
    fi

    # Build PS1 with proper escaping
    PS1="\[$user_color\]\u\[$RESET\]@\[$CYAN\]\h\[$RESET\]:\[$BLUE\]\w\[$RESET\]\[$MAGENTA\]${git_branch}\[$RESET\]\[$env_color\]${env_display}\[$RESET\]\[$GRAY\]${exit_code}\[$RESET\]\n\$ "

    # Set window title
    PS1="\[\e]0;\u@\h: \w\a\]${PS1}"
}
