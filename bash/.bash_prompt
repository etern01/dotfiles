# ~/.bash_prompt - Agnoster-style prompt for bash
# Powerline segments: [user@host] [path] [git] [env]

# ============================================
# Colors
# ============================================
RESET='\[\033[0m\]'
BOLD='\[\033[1m\]'

# Foreground
BLACK='\[\033[0;30m\]'
RED='\[\033[0;31m\]'
GREEN='\[\033[0;32m\]'
YELLOW='\[\033[0;33m\]'
BLUE='\[\033[0;34m\]'
MAGENTA='\[\033[0;35m\]'
CYAN='\[\033[0;36m\]'
WHITE='\[\033[0;37m\]'
GRAY='\[\033[0;90m\]'

# Background
BG_BLACK='\[\033[40m\]'
BG_RED='\[\033[41m\]'
BG_GREEN='\[\033[42m\]'
BG_YELLOW='\[\033[43m\]'
BG_BLUE='\[\033[44m\]'
BG_MAGENTA='\[\033[45m\]'
BG_CYAN='\[\033[46m\]'
BG_WHITE='\[\033[47m\]'
BG_GRAY='\[\033[100m\]'

# Powerline separator
SEGMENT_SEPARATOR=""

# ============================================
# Segment builder
# ============================================
prompt_segment() {
    local bg=$1
    local fg=$2
    local content=$3

    if [[ -n "$CURRENT_BG" && "$CURRENT_BG" != "$bg" ]]; then
        PS1+="${bg}${CURRENT_BG}${SEGMENT_SEPARATOR}${RESET}${bg} "
    else
        PS1+="${bg} "
    fi

    PS1+="${fg}${content}${RESET}"
    CURRENT_BG="$bg"
}

prompt_end() {
    if [[ -n "$CURRENT_BG" ]]; then
        PS1+="${RESET}${CURRENT_BG}${SEGMENT_SEPARATOR}${RESET}"
    fi
    PS1+=" "
}

# ============================================
# Environment detection
# ============================================
detect_env() {
    if [ -n "$ENV_TYPE" ]; then
        echo "$ENV_TYPE"
    elif [[ "$HOSTNAME" == *"prod"* ]] || [[ "$HOSTNAME" == *"production"* ]]; then
        echo "PROD"
    elif [[ "$HOSTNAME" == *"staging"* ]] || [[ "$HOSTNAME" == *"stage"* ]]; then
        echo "STAGE"
    elif [[ "$HOSTNAME" == *"dev"* ]] || [[ "$HOSTNAME" == *"development"* ]]; then
        echo "DEV"
    fi
}

# ============================================
# Git branch
# ============================================
parse_git_branch() {
    git symbolic-ref --short HEAD 2>/dev/null || git describe --tags --exact-match 2>/dev/null
}

# Git dirty status
parse_git_dirty() {
    local status=$(git status --porcelain 2>/dev/null)
    if [[ -n "$status" ]]; then
        echo " ✚"
    fi
}

# ============================================
# Build prompt
# ============================================
build_prompt() {
    local last_exit=$?

    CURRENT_BG=""

    # Exit code segment
    if [[ $last_exit -ne 0 ]]; then
        prompt_segment "$BG_RED" "$WHITE" " ✘ $last_exit "
    fi

    # User@host segment (only if not default user or SSH)
    if [[ "$USER" != "$DEFAULT_USER" || -n "$SSH_CLIENT" ]]; then
        if [[ $EUID -eq 0 ]]; then
            prompt_segment "$BG_YELLOW" "$BLACK" " \u@\h "
        else
            prompt_segment "$BG_BLUE" "$WHITE" " \u@\h "
        fi
    fi

    # Path segment
    prompt_segment "$BG_CYAN" "$BLACK" " \w "

    # Git segment
    local branch=$(parse_git_branch)
    if [[ -n "$branch" ]]; then
        local dirty=$(parse_git_dirty)
        local git_info="  $branch$dirty "

        if [[ -n "$dirty" ]]; then
            prompt_segment "$BG_YELLOW" "$BLACK" "$git_info"
        else
            prompt_segment "$BG_GREEN" "$BLACK" "$git_info"
        fi
    fi

    # Environment segment
    local env=$(detect_env)
    if [[ -n "$env" ]]; then
        case "$env" in
            PROD)
                prompt_segment "$BG_RED" "$WHITE" " $env "
                ;;
            STAGE)
                prompt_segment "$BG_YELLOW" "$BLACK" " $env "
                ;;
            DEV)
                prompt_segment "$BG_CYAN" "$BLACK" " $env "
                ;;
        esac
    fi

    prompt_end

    # New line + prompt symbol
    if [[ $EUID -eq 0 ]]; then
        PS1+="# "
    else
        PS1+="$ "
    fi

    # Window title
    PS1="\[\e]0;\u@\h: \w\a\]${PS1}"
}
