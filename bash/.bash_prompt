# ~/.bash_prompt - Custom prompt configuration
# Powerline-style prompt with root/non-root distinction

# ============================================
# Colors (without \[\] - added in PS1)
# ============================================
RESET='\033[0m'
BOLD='\033[1m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
GRAY='\033[0;90m'

# Background colors
BG_RED='\033[41m'
BG_GREEN='\033[42m'
BG_BLUE='\033[44m'
BG_YELLOW='\033[43m'
BG_MAGENTA='\033[45m'
BG_CYAN='\033[46m'
BG_GRAY='\033[100m'

# Powerline separators
SEP_RIGHT=""
SEP_LEFT=""
GIT_SYMBOL=""

# Fallback to ASCII if powerline fonts not available
if [ -z "${POWERLINE_FONTS:-}" ]; then
    case "$TERM" in
        *linux|*vt*)
            SEP_RIGHT=">"
            SEP_LEFT="<"
            GIT_SYMBOL="*"
            ;;
    esac
fi

# ============================================
# Environment detection
# ============================================
detect_env() {
    if [ -n "$ENV_TYPE" ]; then
        echo "$ENV_TYPE"
    elif [[ "$HOSTNAME" == *"prod"* ]] || [[ "$HOSTNAME" == *"production"* ]]; then
        echo "PROD"
    elif [[ "$HOSTNAME" == *"staging"* ]] || [[ "$HOSTNAME" == *"stage"* ]]; then
        echo "STAGE"
    elif [[ "$HOSTNAME" == *"dev"* ]] || [[ "$HOSTNAME" == *"development"* ]]; then
        echo "DEV"
    fi
}

# ============================================
# Git branch
# ============================================
parse_git_branch() {
    local branch
    branch=$(git symbolic-ref --short HEAD 2>/dev/null || git describe --tags --exact-match 2>/dev/null)
    if [ -n "$branch" ]; then
        echo "$branch"
    fi
}

# ============================================
# Build prompt
# ============================================
build_prompt() {
    # Save exit code FIRST before any other command
    local last_exit=$?

    local git_branch=$(parse_git_branch)
    local env=$(detect_env)

    # Root detection
    local is_root=0
    if [ "$EUID" -eq 0 ]; then
        is_root=1
    fi

    # ============================================
    # Exit code indicator
    # ============================================
    local exit_segment=""
    if [ $last_exit -ne 0 ]; then
        exit_segment="\[$BG_RED\]\[$WHITE\] ✘ \[$RESET\]\[$BG_GRAY\]\[$WHITE\]$SEP_RIGHT\[$RESET\]"
    fi

    # ============================================
    # User@Host segment
    # ============================================
    local user_bg
    local user_fg
    if [ $is_root -eq 1 ]; then
        user_bg=$BG_RED
        user_fg=$WHITE
    else
        user_bg=$BG_GREEN
        user_fg=$WHITE
    fi

    local user_segment="\[$user_bg\]\[$user_fg\] \u@\h \[$RESET\]"

    # ============================================
    # Path segment
    # ============================================
    local path_segment="\[$BG_BLUE\]\[$WHITE\] \w \[$RESET\]\[$BG_YELLOW\]\[$WHITE\]$SEP_RIGHT\[$RESET\]"

    # ============================================
    # Git segment
    # ============================================
    local git_segment=""
    if [ -n "$git_branch" ]; then
        git_segment="\[$BG_YELLOW\]\[$BLACK\] $GIT_SYMBOL $git_branch \[$RESET\]\[$BG_GRAY\]\[$WHITE\]$SEP_RIGHT\[$RESET\]"
    fi

    # ============================================
    # Environment segment
    # ============================================
    local env_segment=""
    local env_bg=""
    local env_fg=$WHITE
    case "$env" in
        PROD)
            env_bg=$BG_RED
            env_segment="\[$env_bg\]\[$env_fg\] $env \[$RESET\]"
            ;;
        STAGE)
            env_bg=$BG_YELLOW
            env_fg=$BLACK
            env_segment="\[$env_bg\]\[$env_fg\] $env \[$RESET\]"
            ;;
        DEV)
            env_bg=$BG_CYAN
            env_segment="\[$env_bg\]\[$env_fg\] $env \[$RESET\]"
            ;;
    esac

    # ============================================
    # Prompt symbol
    # ============================================
    local prompt_symbol="\[$GREEN\]\\$\[$RESET\] "
    if [ $is_root -eq 1 ]; then
        prompt_symbol="\[$RED\]#\[$RESET\] "
    fi

    # ============================================
    # Build PS1
    # ============================================
    PS1="${exit_segment}${user_segment}\[$BG_BLUE\]\[$WHITE\]$SEP_RIGHT\[$RESET\]${path_segment}${git_segment}${env_segment}\n${prompt_symbol}"

    # Set window title
    PS1="\[\e]0;\u@\h: \w\a\]${PS1}"
}
