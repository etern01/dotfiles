# ~/.bash_prompt - Agnoster-style prompt for bash
# Powerline segments with proper bash escape sequences

# ============================================
# Colors (bash PS1 format with \[ \])
# ============================================
RESET='\[\e[0m\]'

# Foreground
BLACK_FG='\[\e[30m\]'
WHITE_FG='\[\e[37m\]'

# Background
BLACK_BG='\[\e[40m\]'
RED_BG='\[\e[41m\]'
GREEN_BG='\[\e[42m\]'
YELLOW_BG='\[\e[43m\]'
BLUE_BG='\[\e[44m\]'
MAGENTA_BG='\[\e[45m\]'
CYAN_BG='\[\e[46m\]'
WHITE_BG='\[\e[47m\]'
GRAY_BG='\[\e[100m\]'

# Powerline separator (U+E0B0)
SEG=$'\ue0b0'

# ============================================
# Environment detection
# ============================================
detect_env() {
    if [ -n "$ENV_TYPE" ]; then
        echo "$ENV_TYPE"
    elif [[ "$HOSTNAME" == *"prod"* ]] || [[ "$HOSTNAME" == *"production"* ]]; then
        echo "PROD"
    elif [[ "$HOSTNAME" == *"staging"* ]] || [[ "$HOSTNAME" == *"stage"* ]]; then
        echo "STAGE"
    elif [[ "$HOSTNAME" == *"dev"* ]] || [[ "$HOSTNAME" == *"development"* ]]; then
        echo "DEV"
    fi
}

# ============================================
# Git branch
# ============================================
parse_git_branch() {
    git symbolic-ref --short HEAD 2>/dev/null || git describe --tags --exact-match 2>/dev/null
}

# Git dirty status
parse_git_dirty() {
    local status=$(git status --porcelain 2>/dev/null)
    if [[ -n "$status" ]]; then
        echo " ✚"
    fi
}

# ============================================
# Build prompt
# ============================================
build_prompt() {
    local last_exit=$?
    local branch=$(parse_git_branch)
    local env=$(detect_env)
    local dirty=""

    if [[ -n "$branch" ]]; then
        dirty=$(parse_git_dirty)
    fi

    # Start with empty PS1
    local ps1=""

    # ============================================
    # Exit code segment
    # ============================================
    if [[ $last_exit -ne 0 ]]; then
        ps1+="${RED_BG}${WHITE_FG} ✘ ${last_exit} ${RESET}"
        ps1+="${RED_BG}${BLACK_FG}${SEG}${RESET}"
    fi

    # ============================================
    # User@host segment
    # ============================================
    local user_bg="${BLUE_BG}"
    local user_fg="${WHITE_FG}"

    if [[ $EUID -eq 0 ]]; then
        user_bg="${YELLOW_BG}"
        user_fg="${BLACK_FG}"
    fi

    if [[ "$USER" != "$DEFAULT_USER" || -n "$SSH_CLIENT" ]]; then
        ps1+="${user_bg}${user_fg} \u@\h ${RESET}"
        ps1+="${user_bg}${BLACK_FG}${SEG}${RESET}"
    fi

    # ============================================
    # Path segment
    # ============================================
    ps1+="${CYAN_BG}${BLACK_FG} \w ${RESET}"

    # ============================================
    # Git segment
    # ============================================
    if [[ -n "$branch" ]]; then
        ps1+="${CYAN_BG}${BLACK_FG}${SEG}${RESET}"

        if [[ -n "$dirty" ]]; then
            ps1+="${YELLOW_BG}${BLACK_FG}  ${branch}${dirty} ${RESET}"
        else
            ps1+="${GREEN_BG}${BLACK_FG}  ${branch}${dirty} ${RESET}"
        fi
    fi

    # ============================================
    # Environment segment
    # ============================================
    if [[ -n "$env" ]]; then
        # Close previous segment
        if [[ -n "$branch" ]]; then
            if [[ -n "$dirty" ]]; then
                ps1+="${YELLOW_BG}${BLACK_FG}${SEG}${RESET}"
            else
                ps1+="${GREEN_BG}${BLACK_FG}${SEG}${RESET}"
            fi
        else
            ps1+="${CYAN_BG}${BLACK_FG}${SEG}${RESET}"
        fi

        case "$env" in
            PROD)
                ps1+="${RED_BG}${WHITE_FG} ${env} ${RESET}"
                ;;
            STAGE)
                ps1+="${YELLOW_BG}${BLACK_FG} ${env} ${RESET}"
                ;;
            DEV)
                ps1+="${CYAN_BG}${BLACK_FG} ${env} ${RESET}"
                ;;
        esac
    fi

    # ============================================
    # End prompt
    # ============================================
    # Close last segment with separator
    if [[ -n "$env" ]]; then
        case "$env" in
            PROD)
                ps1+="${RED_BG}${BLACK_FG}${SEG}${RESET}"
                ;;
            STAGE)
                ps1+="${YELLOW_BG}${BLACK_FG}${SEG}${RESET}"
                ;;
            DEV)
                ps1+="${CYAN_BG}${BLACK_FG}${SEG}${RESET}"
                ;;
        esac
    elif [[ -n "$branch" ]]; then
        if [[ -n "$dirty" ]]; then
            ps1+="${YELLOW_BG}${BLACK_FG}${SEG}${RESET}"
        else
            ps1+="${GREEN_BG}${BLACK_FG}${SEG}${RESET}"
        fi
    else
        ps1+="${CYAN_BG}${BLACK_FG}${SEG}${RESET}"
    fi

    # New line
    ps1+="\n"

    # Prompt symbol
    if [[ $EUID -eq 0 ]]; then
        ps1+="${RED_BG}${WHITE_FG} # ${RESET} "
    else
        ps1+="${GREEN_BG}${BLACK_FG} $ ${RESET} "
    fi

    # Window title
    PS1="\[\e]0;\u@\h: \w\a\]${ps1}"
}
